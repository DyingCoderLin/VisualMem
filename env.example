# VisualMem Configuration Example

# ============================================
# Module Selection
# ============================================
# Type of screen capturer (default: screenshot)
CAPTURER_TYPE=screenshot
# VLM backend type: 'vllm' (any OpenAI-compatible server is in type "vllm", no need to change)
# Storage implementation: 'lancedb' (vector)
STORAGE_TYPE=lancedb
# Storage mode: 'vector' (hybrid search enabled) 
STORAGE_MODE=vector
# Embedding model (default: Qwen3-VL-Embedding-2B, 2048 dim)
EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B

# ============================================
# Preprocessing Parameters
# ============================================
# Frame difference threshold (0.0-1.0). Only frames with diff > threshold are recorded.
SIMPLE_FILTER_DIFF_THRESHOLD=0.006

# UIED-style region detection + text-to-region assignment (default: true). Set false for whole-image OCR only (faster).
# ENABLE_UIED=true

# ============================================
# VLM API Configuration
# ============================================
# API key for the VLM service (set to 'None' for self deployed vLLM without auth)
VLM_API_KEY=None
# VLM_API_KEY=<sk-your-key>
# Base URI for the VLM API
VLM_API_URI=http://localhost:8081
# VLM_API_URI=https://api.openai.com
# Model name or path to the model weights
VLM_API_MODEL=Qwen/Qwen3-VL-8B-Instruct
# VLM_API_MODEL=gpt5

# ============================================
# Daily Report (Map-Reduce pipeline, cloud LLM via litellm)
# ============================================
# Required: API key for the gateway below. Defaults: SJTU OpenAI-compatible API + qwen3coder.
REPORT_API_KEY=
REPORT_API_BASE=https://models.sjtu.edu.cn/api/v1
# REPORT_MAP_MODEL=openai/qwen3coder
# REPORT_REDUCE_MODEL=openai/qwen3coder
# REPORT_MAP_MODEL=openai/deepseek-r1
# Data platform defaults to http://localhost:18080. Override only if needed:
# REPORT_DATA_API_BASE=http://localhost:18080
# Prior daily_report_*.json for Reduce (optional context for today_summary; default logs/, last 14 days)
# REPORT_LOG_DIR=logs
# REPORT_HISTORY_DAYS=14
# ============================================
# Query Enhancement (RAG Workflow)
# ============================================
# Enable LLM to rewrite/expand the user query for better retrieval
ENABLE_LLM_REWRITE=true
# Enable automatic time range extraction from natural language queries
ENABLE_TIME_FILTER=true
# Number of expanded queries to generate
QUERY_REWRITE_NUM=3
# Enable Hybrid Search (combining Dense/Vector search and Sparse/OCR search). If flase, Sparse search will be disabled
ENABLE_HYBRID=true
# Maximum number of images to load for each query(making it at mosty 3*2*20=120 with default settings)
MAX_IMAGES_TO_LOAD=20

# Optional: Independent API for Query Rewrite (defaults to VLM config if not set)
QUERY_REWRITE_API_KEY=<sk-your-key>
QUERY_REWRITE_BASE_URL=http://your-api-endpoint
QUERY_REWRITE_MODEL=gpt-5.4

# ============================================
# Reranker Configuration(only local)
# ============================================
# Enable a second-stage reranking using a multimodal model（if true, make sure you have at least 8GB GPU memory available)
ENABLE_RERANK=false
# Number of top results to keep after reranking
RERANK_TOP_K=20
# Model used for reranking (e.g. a smaller VLM)
RERANK_MODEL=Qwen/Qwen3-VL-Reranker-2B

# ============================================
# Activity Clustering Configuration
# ============================================
# Enable activity clustering and timeline generation.
# When enabled, frames are grouped into activity sessions using embeddings + optional VLM labeling.
# Requires extra compute; disable to save resources (default: false).
ENABLE_CLUSTERING=false
# Cluster labeling: OpenAI-compatible chat.completions at {CLUSTER_VLM_URL}/v1/chat/completions
# CLUSTER_VLM_URL=https://models.sjtu.edu.cn/api
# API key for cluster labeling (if empty, falls back to VLM_API_KEY).
# CLUSTER_VLM_API_KEY=<sk-your-key>
# Default model id (vision; text-only uses CLUSTER_VLM_TEXT_MODEL if set, else this).
# Use the exact id your gateway accepts (e.g. litellm: provider/model such as openai/minimax-m2.5).
# CLUSTER_VLM_MODEL=minimax-m2.5
# Cluster VLM: include screenshot in labeling request (true) or use text-only prompt (false).
# When false, scripts/backfill_activity_clusters.py skips FFmpeg frame decode in discover/label (OCR+layout only).
# When false, realtime/recalculate also skip the VLM call if OCR and region layout are both empty (no image fallback).
# CLUSTER_VLM_USE_VISION=true
# Optional model override for text-only mode only.
# CLUSTER_VLM_TEXT_MODEL=Qwen/Qwen3.5-9B
# Max OCR chars used in cluster label prompt (text-only and vision share same text context).
# CLUSTER_VLM_TEXT_OCR_MAX_CHARS=2000
# Whether to append OCR region layout (bbox + text) into text-only prompt.
# CLUSTER_VLM_INCLUDE_REGION_LAYOUT=true
#
# Test connectivity (replace key if needed):
# curl -sS -X POST "${CLUSTER_VLM_URL}/v1/chat/completions" \
#   -H "Content-Type: application/json" \
#   -H "Authorization: Bearer ${CLUSTER_VLM_API_KEY}" \
#   -d '{"model":"minimax-m2.5","messages":[{"role":"user","content":"reply with ok"}],"temperature":0.1,"max_tokens":16}'

# ============================================
# Storage Paths
# ============================================
# Root directory for all visual memory data
STORAGE_ROOT=./visualmem_storage
# Path to store captured screenshot images
IMAGE_STORAGE_PATH=./visualmem_storage/visualmem_image
# Path for the LanceDB vector database
LANCEDB_PATH=./visualmem_storage/visualmem_lancedb
# Path for the SQLite database (OCR and metadata)
OCR_DB_PATH=./visualmem_storage/visualmem_ocr.db
# Path for the OCR text vector index
TEXT_LANCEDB_PATH=./visualmem_storage/visualmem_textdb

# ============================================
# GUI & Remote Mode
# ============================================
# GUI_MODE: 
#   - 'local' : All processing (OCR, Embedding, Storage) happens on the local machine.
#   - 'remote': your local machine can't handle embedding& reranking, GUI only captures and sends frames to a remote backend server.
GUI_MODE=local
# URL of the remote backend server (only used if GUI_MODE=remote)
# GUI_REMOTE_BACKEND_URL=http://127.0.0.1:8080

# ============================================
# Benchmark Configuration (Optional)
# ============================================
# Name of the benchmark dataset to use
# BENCHMARK_NAME=VideoWatching
# Root path for benchmark images
BENCHMARK_IMAGE_ROOT=./visualmem_storage/visualmem_image/benchmarks
# Root path for benchmark databases
BENCHMARK_DB_ROOT=./visualmem_storage/dbs_benchmark

# ============================================
# Runtime Parameters
# ============================================
# Interval between screen captures in seconds
CAPTURE_INTERVAL_SECONDS=3
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
