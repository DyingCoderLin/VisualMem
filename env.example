# VisualMem — copy to `.env` and adjust what you need.
# More keys and defaults: `config.py` (search `os.environ.get`).

# =============================================================================
# VLM — multimodal Q&A over screenshots
# Prefer a vision model (e.g. Qwen3-VL).
# =============================================================================

# --- A) Local OpenAI-compatible vLLM (no auth: leave key as None) ---
# VLM_API_KEY=None
# VLM_API_URI=http://127.0.0.1:8081
# VLM_API_MODEL=Qwen/Qwen3-VL-8B-Instruct

# --- B) Cloud API (key + base + gateway model id) ---
VLM_API_KEY=<your-api-key>
VLM_API_URI=https://models.sjtu.edu.cn/api
VLM_API_MODEL=qwen3vl

# =============================================================================
# Query rewrite (optional; text-only — omit to use VLM settings)
# =============================================================================
# QUERY_REWRITE_API_KEY=<your-api-key>
# QUERY_REWRITE_BASE_URL=https://models.sjtu.edu.cn/api
# QUERY_REWRITE_MODEL=glm-5

# =============================================================================
# Embeddings (vector index). Default SigLIP is lighter; Qwen3-VL-Embedding-2B is heavier.
# =============================================================================
EMBEDDING_MODEL=google/siglip-large-patch16-384
# EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B

# =============================================================================
# GUI mode — local = capture + OCR + embedding on this machine (default)
# =============================================================================
GUI_MODE=local
# GUI_MODE=remote
# GUI_REMOTE_BACKEND_URL=http://127.0.0.1:8080

# =============================================================================
# RAG / retrieval
# =============================================================================
ENABLE_LLM_REWRITE=true
ENABLE_TIME_FILTER=true
QUERY_REWRITE_NUM=3
ENABLE_HYBRID=true
MAX_IMAGES_TO_LOAD=20
ENABLE_RERANK=false
# RERANK_MODEL=Qwen/Qwen3-VL-Reranker-2B

# =============================================================================
# Activity clustering (timeline / daily report inputs)
# =============================================================================
ENABLE_CLUSTERING=true
CLUSTER_VLM_URL=https://models.sjtu.edu.cn/api
CLUSTER_VLM_API_KEY=<your-api-key>

# =============================================================================
# Daily report (Map–Reduce via litellm; GUI depends on this)
# =============================================================================
REPORT_API_KEY=<your-api-key>
REPORT_API_BASE=https://models.sjtu.edu.cn/api/v1
REPORT_LOG_DIR=logs
REPORT_HISTORY_DAYS=14

# =============================================================================
# Optional
# =============================================================================
# STORAGE_ROOT=./visualmem_storage
# BENCHMARK_NAME=
# BENCHMARK_IMAGE_ROOT=./visualmem_storage/visualmem_image/benchmarks
# BENCHMARK_DB_ROOT=./visualmem_storage/dbs_benchmark
# SIMPLE_FILTER_DIFF_THRESHOLD=0.006
# CAPTURE_INTERVAL_SECONDS=3
# ENABLE_UIED=true
# LOG_LEVEL=INFO
